# Copy to .env.local for dev. On Unraid, set these in the container template / compose.

# No auth vars: the app has no login (LAN/Tailscale-only, read-only — see plan/00-overview.md).

# --- Integrations (each optional; card hides when unset) ---
# URL convention (see plan/02-deployment.md):
#   dev:    Tailscale hostname of the Unraid host, e.g. http://unraid.<tailnet>.ts.net:32400
#   unraid: container name on the shared Docker network, e.g. http://plex:32400

# Tautulli (also covers Plex activity/library data — Plex itself isn't
# tailnet-reachable, so Tautulli, which talks to the local Plex server
# directly, stands in for it)
TAUTULLI_URL=
TAUTULLI_API_KEY=

# SABnzbd
SABNZBD_URL=
SABNZBD_API_KEY=

# Radarr
RADARR_URL=
RADARR_API_KEY=

# Sonarr
SONARR_URL=
SONARR_API_KEY=

# Seerr (Overseerr-compatible)
SEERR_URL=
SEERR_API_KEY=
